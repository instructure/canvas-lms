{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2020", "ESNext"],
    "incremental": false,
    "module": "es2020",
    "moduleResolution": "node",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2020",
    "noImplicitAny": true,
    "baseUrl": "./ui",
    "paths": {
      "@canvas/*": ["shared/*"],
      "@instructure/platform-query/broadcast": ["../node_modules/@instructure/platform-query/dist/broadcast.d.ts"],
      "@instructure/platform-query/queryify": ["../node_modules/@instructure/platform-query/dist/queryify.d.ts"],
      "@instructure/outcomes-ui/lib/*": ["../node_modules/@instructure/outcomes-ui/lib/*"],
      "@instructure/outcomes-ui/es/*": ["../node_modules/@instructure/outcomes-ui/lib/*"],
      "@instructure/*": ["../packages/*"]
    },
    "plugins": [
      {
        "name": "@0no-co/graphqlsp",
        "schema": "./schema.graphql"
      }
    ],
    "types": ["vitest/globals", "jqueryui"]
  },
  "include": ["ui/**/*.ts", "ui/**/*.tsx", "ui/**/*.d.ts"],
  "exclude": ["node_modules"]
}
